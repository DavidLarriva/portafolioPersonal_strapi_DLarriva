{
  "kind": "collectionType",
  "collectionName": "proyectos",
  "info": {
    "singularName": "proyecto",
    "pluralName": "proyectos",
    "displayName": "Proyecto"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string"
    },
    "descripcion_breve": {
      "type": "text"
    },
    "descripcion_completa": {
      "type": "blocks"
    },
    "imagen_principal": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "tipo_proyecto": {
      "type": "enumeration",
      "enum": [
        "academico",
        "personal",
        "laboral",
        "simulado"
      ]
    },
    "diseno_interfaces": {
      "type": "string"
    },
    "tecnologias": {
      "type": "string"
    },
    "enlace_repositorio": {
      "type": "string"
    },
    "enlace_demo": {
      "type": "string"
    },
    "destacado": {
      "type": "boolean"
    },
    "slug": {
      "type": "uid",
      "targetField": "nombre"
    },
    "programadores": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::programador.programador",
      "inversedBy": "proyectos"
    }
  }
}
